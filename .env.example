# =============================================================================
# whatsappbot — copy to .env.local for local dev, set in Netlify for production
# =============================================================================

# -----------------------------------------------------------------------------
# Meta / WhatsApp (required for bot + webhook)
# -----------------------------------------------------------------------------
# Create any random string — must match Meta Dashboard → WhatsApp → Configuration → Verify token
META_VERIFY_TOKEN=

# Meta Business Settings → System Users → Generate token (never commit the real value)
# Graph API Explorer tokens expire ~24h — use a permanent System User token in production
META_ACCESS_TOKEN=

# Spark bot — Meta Dashboard → WhatsApp → API Setup → Phone number ID
WHATSAPP_PHONE_NUMBER_ID=

# SodaMax bot — second WhatsApp number (Products & Refill, SodaMax orders)
WHATSAPP_PHONE_NUMBER_ID_2=

# Optional — "Other Query" CTA support number (defaults to 23058875050)
# SODAMAX_SUPPORT_WHATSAPP_NUMBER=23058875050

# -----------------------------------------------------------------------------
# Supabase (required)
# Get all keys from: https://supabase.com/dashboard → your project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser. Same project → Settings → API → service_role
SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# SodaMax store checkout links (Products & Refill) — REQUIRED for signed ?s= URLs
# -----------------------------------------------------------------------------
# Generate once (see below), then paste the SAME value in sodamax_order_platform .env
# SODAMAX_CHECKOUT_SESSION_SECRET=
#
# How to generate (pick one):
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   Or use a password manager’s “generate password” (32+ random characters)
#
# Use one secret for both apps. Do not rotate unless you redeploy both at the same time.

# Live store URL (defaults to https://sodamax-online-order.netlify.app if omitted)
# SODAMAX_ORDER_PLATFORM_URL=https://sodamax-online-order.netlify.app

# Local store testing only:
# SODAMAX_ORDER_PLATFORM_URL=http://localhost:5173

# Optional — SodaMax new machine product UUID from dashboard → WhatsApp Product
# SODAMAX_NEW_MACHINE_PRODUCT_ID=

# Optional — protects /api/cron/session-reminders if you schedule reminders
# CRON_SECRET=
