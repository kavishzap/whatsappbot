# Meta webhook verification (required for Meta "Verify and save")
# Use the same value in Meta Dashboard → WhatsApp → Configuration → Verify token
META_VERIFY_TOKEN=

# Required for sending WhatsApp replies (server-only — never expose to the client)
# Temporary tokens from Graph API Explorer expire in ~24 hours.
# For production, create a permanent System User token in Meta Business Settings.
# META_ACCESS_TOKEN=your_long_lived_or_system_user_token
# WHATSAPP_PHONE_NUMBER_ID=1158239950704779

# Second WhatsApp number (SodaMax bot — uses Products page catalog)
# WHATSAPP_PHONE_NUMBER_ID_2=

# Optional SodaMax support number for "Over Query" CTA (defaults to 23057833020)
# SODAMAX_SUPPORT_WHATSAPP_NUMBER=

# Supabase (public keys — safe for client-side auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — used by dashboard API routes to call Supabase Edge Functions
# SERVICE_ROLE_KEY=
